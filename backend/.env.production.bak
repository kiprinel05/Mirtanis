# Copy to backend/.env on the server and adjust the values below.

# --- App ---
APP_NAME=Mirtanis Events API
API_V1_PREFIX=/api/v1

# --- Database (must match docker-compose POSTGRES_* values) ---
DATABASE_URL=sqlite:///./mirtanis.db
CORS_ORIGINS=http://localhost:4200
UPLOAD_DIR=./uploads
APP_ENV=development
DEBUG=True
# --- Security ---
# Generate with: 
JWT_SECRET_KEY=4i9koxmOXJQ9ndCf7Ot-yQfHR1c4HEUzTBzZckSg0lrKHtt-kSDGZpJ6LAXePietqBqWDGlBmTUNQ093u50x4A
JWT_ALGORITHM=HS256
