# Copy to backend/.env on the server and adjust the values below.

# --- App ---
APP_NAME=Mirtanis Events API
APP_ENV=production
DEBUG=False
API_V1_PREFIX=/api/v1

# --- Database (must match docker-compose POSTGRES_* values) ---
DATABASE_URL=postgresql+psycopg2://mirtanis:mirtanis@db:5432/mirtanis_events

# --- Security ---
# Generate with: 
JWT_SECRET_KEY=4i9koxmOXJQ9ndCf7Ot-yQfHR1c4HEUzTBzZckSg0lrKHtt-kSDGZpJ6LAXePietqBqWDGlBmTUNQ093u50x4A
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# --- Admin bootstrap (used only on first boot) ---
ADMIN_EMAIL=admin@mirtanisevents.ro
ADMIN_PASSWORD=parolaputernica

# --- CORS (production domain only) ---
CORS_ORIGINS=https://mirtanisevents.ro,https://www.mirtanisevents.ro

# --- Uploads ---
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_MB=15

# --- Cloudflare R2 gallery (optional) ---
# Set all of these to serve the public gallery straight from an R2 bucket.
# Organise images in category folders to enable filtering, e.g.:
#   nunti/poza1.jpg, botezuri/poza2.jpg, cort/poza3.jpg
# (folder names must match: nunti, botezuri, petreceri, exterior, lac, cort, sala)
R2_ACCOUNT_ID=ce40a1599219dbb627edeea901c9669a
R2_ACCESS_KEY_ID=02431eb348da170d810c8309f62cadff
R2_SECRET_ACCESS_KEY=46a98a68aff53e78dc0f10c46ad0d680f8ff9678fc7735795e23b662273c19cc
R2_BUCKET=https://ce40a1599219dbb627edeea901c9669a.r2.cloudflarestorage.com
# Public dev URL (https://pub-xxxx.r2.dev) or your custom domain bound to the bucket
R2_PUBLIC_BASE=https://pub-c33acb9dab534aff842fc683081dc6d6.r2.dev
# Optional: only list a sub-folder of the bucket, e.g. gallery/
R2_PREFIX=
