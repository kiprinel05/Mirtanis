# Copy to backend/.env on the server and adjust the values below.

# --- App ---
APP_NAME=Mirtanis Events API
APP_ENV=production
DEBUG=False
API_V1_PREFIX=/api/v1

# --- Database (must match docker-compose POSTGRES_* values) ---
DATABASE_URL=postgresql+psycopg2://mirtanis:mirtanis@db:5432/mirtanis_events

# --- Security ---
# Generate with: 
JWT_SECRET_KEY=4i9koxmOXJQ9ndCf7Ot-yQfHR1c4HEUzTBzZckSg0lrKHtt-kSDGZpJ6LAXePietqBqWDGlBmTUNQ093u50x4A
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# --- Admin bootstrap (used only on first boot) ---
ADMIN_EMAIL=admin@mirtanisevents.ro
ADMIN_PASSWORD=parolaputernica

# --- CORS (production domain only) ---
CORS_ORIGINS=https://mirtanisevents.ro,https://www.mirtanisevents.ro

# --- Uploads ---
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_MB=15
