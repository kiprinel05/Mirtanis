# Copy this file to `.env` and fill in real values.

# ---- App ----
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=http://localhost:4200,https://fotobugeac.ro

# ---- Database ----
# SQLite is fine for development. For production, point at Postgres:
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/foto_bugeac
DATABASE_URL=sqlite:///./foto_bugeac.db

# ---- Security ----
SECRET_KEY=please-generate-a-long-random-string-here
ACCESS_TOKEN_EXPIRE_MINUTES=720

# Optional: bootstraps a default admin on first startup.
BOOTSTRAP_ADMIN_EMAIL=studio@fotobugeac.ro
BOOTSTRAP_ADMIN_PASSWORD=changeme-strong-password

# ---- Cloudflare R2 ----
# Find these in Cloudflare dashboard → R2 → Manage R2 API Tokens.
R2_ACCOUNT_ID=your-cf-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET=foto-bugeac
# Optional: serve previews from a custom domain.
# R2_PUBLIC_BASE_URL=https://cdn.fotobugeac.ro
# Optional override (otherwise derived from R2_ACCOUNT_ID):
# R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com

# ---- TTLs ----
PREVIEW_URL_TTL_SECONDS=3600
DOWNLOAD_URL_TTL_SECONDS=900

# ---- Upload ----
MAX_UPLOAD_SIZE_MB=50

# ---- SMTP (booking emails) ----
# For Gmail: enable 2FA, generate an App Password,
# put it as SMTP_PASS (not your account password).

